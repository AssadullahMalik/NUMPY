import numpy as np

A = np.array([[1, 2], [3, 4]])
B = np.array([[5, 6], [7, 8]])

# Matrix multiplication
print("Dot Product:\n", np.dot(A, B))

# Determinant
print("Determinant:", np.linalg.det(A))

# Inverse
print("Inverse:\n", np.linalg.inv(A))

# Eigenvalues
values, vectors = np.linalg.eig(A)
print("Eigenvalues:", values)
